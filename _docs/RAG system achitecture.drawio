                </mxCell>
                <mxCell id="dBKMSmHQh9OrBfHsh_P9-28" value="&lt;b&gt;User Story 1 (everyday usage):&lt;/b&gt;&lt;div&gt;I open the UI and the system automatically creates and opens a new session. Then I select the documents (checkboxes) I want to use. In the main center area I ask the RAG system a question about the selected documents. After some time I get the response. My question and the response are saved and displayed in the center area.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="222" y="1047" width="200" height="183" as="geometry"/>
                </mxCell>
                <mxCell id="dBKMSmHQh9OrBfHsh_P9-29" value="&lt;b&gt;User Story 2 (file upload):&lt;/b&gt;&lt;div&gt;I open the UI.&amp;nbsp;&lt;span style=&quot;background-color: initial;&quot;&gt;I drag documents onto the right part of the window to upload a file for indexing. The files status in pending/indexing. After some time the file turns into indexed and fully usable in any other session. (old or new)&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="434" y="1047" width="200" height="183" as="geometry"/>
                </mxCell>
                <mxCell id="dBKMSmHQh9OrBfHsh_P9-30" value="&lt;b&gt;User Story 3 (opening previous seesion):&lt;/b&gt;&lt;div&gt;I open the UI. On the left side of the window I select one of my previous chats. By clicking it I open it. The chat history apears in the center area. I can continue chatting in this chat/session.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="222" y="1240" width="200" height="183" as="geometry"/>
                </mxCell>
                <mxCell id="Zz72XPGM2RTjF0w5ItkM-1" value="&lt;b&gt;General description:&lt;/b&gt;&lt;div&gt;This is a single user system. With a database service for persistent storage.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;It allows you to upload pdf lecture slides/materials. The system then indexes the uploaded files.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;The user can ask question about the uploaded and selected files.&amp;nbsp;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="-324" y="950" width="493" height="183" as="geometry"/>
                </mxCell>
                <mxCell id="jZKQEIBSfkqtFi6f2tL6-1" value="&lt;b&gt;!!! This is an older version when we still didn&#39;t deside on a topic. Some language is outdated, but the general idea is the same !!!&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
                    <mxGeometry x="-374" y="1465" width="814" height="32" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
